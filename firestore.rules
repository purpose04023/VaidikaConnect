/**
 * This ruleset enforces a security model for the VaidikaConnect application,
 * balancing user privacy with public discoverability of pujari profiles and puja information.
 *
 * Core Philosophy:
 * The rules establish a strict ownership model for private user data while allowing public read
 * access to shared content like pujari profiles and puja catalogs. The primary goal is to
 * ensure that users can only modify their own data, pujaris can only modify their own profiles,
 * and private communications remain confidential.
 *
 * Data Structure:
 * The data is organized into several top-level collections:
 * - /userProfiles/{userId}: Private data for each application user, accessible only by that user.
 * - /pujariProfiles/{pujariId}: Publicly readable profiles for pujaris. Only the pujari can modify their own profile. This collection has a subcollection for reviews.
 * - /puja/{pujaId}: A public, read-only catalog of available pujas.
 * - /chatMessages/{chatId}: A collection for private messages between users and pujaris.
 *
 * Key Security Decisions:
 * - User and Pujari Listing: Listing all user profiles (/userProfiles) is disabled to protect user privacy. Listing pujari profiles is enabled to allow discovery. Listing all chat messages is disabled.
 * - Ownership: All write operations are strictly controlled by ownership checks. For user-specific data, this is based on the document's path ({userId}). For user-generated content like reviews and chats, this is based on a `userId` or `senderId` field stored directly on the document.
 * - Relational Integrity: On creation, rules validate that ownership fields (e.g., `userId`, `senderId`) match the authenticated user, and path-relevant fields (e.g., `pujariId` on a review) are set correctly. These critical fields are immutable once set.
 * - Default Posture: Any operation not explicitly granted is denied. Client-side modification of shared, public data like the puja catalog is forbidden.
 *
 * Denormalization for Authorization:
 * To ensure fast and secure authorization checks, this ruleset relies on denormalized data:
 * - /pujariProfiles/{pujariId}/reviews/{reviewId}: Each review document contains a `userId` field. This allows rules to verify review ownership without performing a costly and insecure cross-collection `get()`.
 * - /chatMessages/{chatId}: Each message document contains `senderId` and `receiverId` fields. This allows rules to grant access only to the two participants of the conversation directly from the document being accessed.
 *
 * Structural Segregation:
 * - User profiles (`userProfiles`) and pujari profiles (`pujariProfiles`) are in separate top-level collections. This provides a clear security boundary and allows for efficient, secure querying (e.g., list all pujaris) without the risk of exposing private user data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for reusable logic
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the requesting user's UID matches the provided userId.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Checks ownership for an existing document, ensuring it's not null.
    // Use for update and delete operations.
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // Checks if the user is a participant (sender or receiver) in a chat.
    function isChatParticipant() {
      return isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
    }
    
    // Validates that critical, immutable fields haven't changed during an update.
    function areRelationalIdsImmutableForUser(userId) {
        return request.resource.data.id == resource.data.id && request.resource.data.id == userId;
    }
    
    // Validates that critical, immutable fields for a review haven't changed.
    function areRelationalIdsImmutableForReview() {
        return request.resource.data.id == resource.data.id
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.pujariId == resource.data.pujariId;
    }


    /**
     * @description Controls access to user profile documents.
     * @path /userProfiles/{userId}
     * @allow (create) An authenticated user can create their own profile document.
     * @deny (get) Another user cannot read this user's profile.
     * @principle Restricts access to a user's own data tree.
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && areRelationalIdsImmutableForUser(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to pujari profiles, which are publicly viewable but privately managed.
     * @path /pujariProfiles/{pujariId}
     * @allow (get) Any user, signed in or not, can view a pujari's profile.
     * @deny (update) An authenticated user who is not the pujari cannot update the profile.
     * @principle Implements public read with owner-only writes.
     */
    match /pujariProfiles/{pujariId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(pujariId) && request.resource.data.id == pujariId;
      allow update: if isExistingOwner(pujariId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(pujariId);

      /**
       * @description Controls access to reviews for a specific pujari.
       * @path /pujariProfiles/{pujariId}/reviews/{reviewId}
       * @allow (create) An authenticated user can create a review for a pujari.
       * @deny (update) A user cannot update a review written by another user.
       * @principle Enforces document ownership for user-generated content and validates relational integrity.
       */
      match /reviews/{reviewId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.pujariId == pujariId;
        allow update: if isExistingOwner(resource.data.userId) && areRelationalIdsImmutableForReview();
        allow delete: if isExistingOwner(resource.data.userId);
      }
    }

    /**
     * @description Controls access to the public catalog of puja information.
     * @path /puja/{pujaId}
     * @allow (list) Any client can list all available pujas.
     * @deny (create) No client is permitted to create, update, or delete puja entries. This is managed server-side.
     * @principle Secures data as public and read-only for all clients.
     */
    match /puja/{pujaId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to private chat messages between users and pujaris.
     * @path /chatMessages/{chatId}
     * @allow (get) The sender or the receiver of a message can read it.
     * @deny (list) No user can list all chat messages in the database.
     * @principle Restricts access to a specific set of collaborators (sender and receiver).
     */
    match /chatMessages/{chatId} {
      allow get: if isChatParticipant();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if false;
      allow delete: if resource != null && isOwner(resource.data.senderId);
    }
  }
}